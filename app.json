{
  "expo": {
    "name": "Resenha Score",
    "slug": "resenha-score",
    "scheme": "resenha-score",
    "version": "1.0.0-beta",
    "orientation": "portrait",
    "icon": "./assets/images/olhos.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/olhos.png",
      "resizeMode": "contain",
      "backgroundColor": "#004643"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/olhos.png",
        "backgroundColor": "#004643"
      },
      "package": "com.anonymous.resenhascore"
    },
    "plugins": [
      "@react-native-community/datetimepicker",
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "502e02a3-77d0-4f3c-8022-083129559b91"
      }
    }
  }
}
